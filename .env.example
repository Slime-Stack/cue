# MongoDB Atlas connection string
# Create a free M0 cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cue
MONGODB_URI=mongodb+srv://cue-user:CHANGEME@cluster0.xxxxx.mongodb.net/cue

# Google Cloud (set by ADK scaffold, usually auto-detected)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global
